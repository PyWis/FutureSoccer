SECRET_KEY=cambia-questa-chiave-segreta-in-produzione
DATABASE_URL=sqlite:///futuresoccer.db

# Orologio di gioco: secondi reali per ogni giorno di gioco
# 300 = 5 minuti reali = 1 giorno di gioco (default)
# Il gioco parte il 31 agosto 2099
GAME_CLOCK_RATIO=300

# Coefficiente di conversione goal: probabilità base per turno = GOAL_COEFF * valore_goal
# Valori più alti → più goal per partita (default 0.3)
GOAL_COEFF=0.3

# Brevo (Sendinblue) API
BREVO_API_KEY=tua-api-key-brevo
BREVO_SENDER_EMAIL=noreply@futuresoccer.com
BREVO_SENDER_NAME=FutureSoccer

# Superadmin iniziale
ADMIN_USERNAME=fusoccer
ADMIN_EMAIL=admin@futuresoccer.com
ADMIN_PASSWORD=admin
