# Imposta FLASK_ENV=production in produzione: rende obbligatori SECRET_KEY e
# ADMIN_PASSWORD non di default, e attiva i cookie Secure (solo HTTPS).
FLASK_ENV=development

# OBBLIGATORIO in produzione. Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-questa-chiave-segreta-in-produzione
DATABASE_URL=sqlite:///futuresoccer.db

# Debug server di sviluppo (NON usare in produzione). Espone la console RCE di Werkzeug.
FLASK_DEBUG=0
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000

# Orologio di gioco: secondi reali per ogni giorno di gioco
# 300 = 5 minuti reali = 1 giorno di gioco (default)
# Il gioco parte il 31 agosto 2099
GAME_CLOCK_RATIO=300

# Coefficiente di conversione goal: probabilità base per turno = GOAL_COEFF * valore_goal
# Valori più alti → più goal per partita (default 0.3)
GOAL_COEFF=0.3

# Probabilità base infortuni per turno (ridotta da resistenza e strutture del campo)
# Valori più alti → più infortuni per partita (default 0.010 = 1%)
INJURY_BASE=0.010

# Brevo (Sendinblue) API
BREVO_API_KEY=tua-api-key-brevo
BREVO_SENDER_EMAIL=noreply@futuresoccer.com
BREVO_SENDER_NAME=FutureSoccer

# Superadmin iniziale.
# In produzione ADMIN_PASSWORD è OBBLIGATORIO e non può essere 'admin' (l'avvio fallisce).
# In sviluppo, se omesso o uguale a 'admin', viene generata una password casuale
# stampata nei log all'avvio.
ADMIN_USERNAME=fusoccer
ADMIN_EMAIL=admin@futuresoccer.com
ADMIN_PASSWORD=
